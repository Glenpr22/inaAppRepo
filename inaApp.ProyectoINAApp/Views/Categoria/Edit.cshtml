@using inaApp.ProyectoINAApp.Models.Categoria
@model CategoriaEditViewModel

@{
    ViewData["Title"] = "Editar Categoría";
}

<div class="crud-container crud-edit">

    <div class="crud-encabezado text-center">
        <h2>Modificar Categoría</h2>

        <p class="crud-descripcion">
            Actualice la información de la categoría seleccionada.
        </p>
    </div>

    <form asp-action="Edit"
          method="post"
          class="crud-formulario">

        <input asp-for="Id" type="hidden" />

        @* Déjalo únicamente si CategoriaEditViewModel contiene Estado *@
        @* <input asp-for="Estado" type="hidden" /> *@

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="crud-campo">
            <label asp-for="Nombre"></label>

            <input asp-for="Nombre"
                   class="form-control"
                   placeholder="Ingrese el nombre de la categoría" />

            <span asp-validation-for="Nombre"
                  class="text-danger">
            </span>
        </div>

        <div class="crud-acciones">

            <a asp-action="Index"
               class="crud-btn crud-btn-volver">
                Cancelar
            </a>

            <button type="submit"
                    class="crud-btn crud-btn-editar">
                Guardar cambios
            </button>

        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}