@using inaApp.ProyectoINAApp.Models.Producto
@model ProductoEditViewModel

@{
    ViewData["Title"] = "Modificar Producto";
}

<div class="crud-container crud-edit">

    <div class="crud-encabezado text-center">
        <h2>Modificar Producto</h2>

        <p class="crud-descripcion">
            Actualice la información y categoría del producto seleccionado.
        </p>
    </div>

    <form asp-action="Edit"
          method="post"
          class="crud-formulario">

        <input asp-for="Id"
               type="hidden" />

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="crud-grid">

            <div class="crud-campo">
                <label asp-for="Nombre"></label>

                <input asp-for="Nombre"
                       class="form-control"
                       placeholder="Ingrese el nombre del producto" />

                <span asp-validation-for="Nombre"
                      class="text-danger">
                </span>
            </div>

            <div class="crud-campo">
                <label asp-for="CategoriaId">
                    Categoría
                </label>

                <div class="crud-select-contenedor">

                    <select asp-for="CategoriaId"
                            asp-items="Model.Categorias"
                            class="form-select crud-select">

                        <option value="">
                            Seleccione una categoría
                        </option>

                    </select>

                </div>

                <small class="crud-ayuda">
                    Puede cambiar la categoría actual del producto.
                </small>

                <span asp-validation-for="CategoriaId"
                      class="text-danger">
                </span>
            </div>

            <div class="crud-campo crud-campo-completo">
                <label asp-for="Descripcion"></label>

                <textarea asp-for="Descripcion"
                          class="form-control crud-textarea"
                          rows="4"
                          placeholder="Ingrese una descripción del producto">
                </textarea>

                <span asp-validation-for="Descripcion"
                      class="text-danger">
                </span>
            </div>

            <div class="crud-campo">
                <label asp-for="Precio"></label>

                <div class="crud-input-prefijo">
                    <span>₡</span>

                    <input asp-for="Precio"
                           class="form-control"
                           type="number"
                           step="0.01"
                           min="0"
                           placeholder="0.00" />
                </div>

                <span asp-validation-for="Precio"
                      class="text-danger">
                </span>
            </div>

            <div class="crud-campo">
                <label asp-for="Stock"></label>

                <input asp-for="Stock"
                       class="form-control"
                       type="number"
                       min="0"
                       placeholder="Cantidad disponible" />

                <span asp-validation-for="Stock"
                      class="text-danger">
                </span>
            </div>

        </div>

        <div class="crud-acciones">

            <a asp-action="Index"
               class="crud-btn crud-btn-volver">
                Cancelar
            </a>

            <button type="submit"
                    class="crud-btn crud-btn-editar">
                Guardar cambios
            </button>

        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}