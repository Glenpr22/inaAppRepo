@{
}
@using inaApp.ProyectoINAApp.Models.Producto
@model List<ProductoIndexViewModel>

@{
    ViewData["Title"] = "Productos";
}

<div class="container mt-4 productos-container">

    <div class="productos-encabezado">
        <h2>VISTA PRODUCTOS</h2>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="productos-subtitulo">Listado de Productos</h2>

        <a asp-action="Create"
           class="btn btn-producto btn-crear-producto">
            Crear Producto
        </a>
    </div>

    <div class="table-responsive productos-tabla-container">
        <table class="table table-bordered table-striped table-hover productos-tabla">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Categoría</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var producto in Model)
                    {
                        <tr>
                            <td>@producto.Id</td>
                            <td>@producto.Nombre</td>
                            <td>@producto.Descripcion</td>
                            <td>₡@producto.Precio.ToString("N2")</td>
                            <td>@producto.Stock</td>
                            <td>@producto.CategoriaNombre</td>

                            <td class="text-center acciones-producto">
                                <a asp-action="Details"
                                   asp-route-id="@producto.Id"
                                   class="btn btn-sm btn-producto btn-detalles-producto">
                                    Detalles
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@producto.Id"
                                   class="btn btn-sm btn-producto btn-modificar-producto">
                                    Modificar
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@producto.Id"
                                   class="btn btn-sm btn-producto btn-eliminar-producto">
                                    Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center productos-vacio">
                            No existen productos registrados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>